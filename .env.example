# ============================================
# CRYPTO DASHBOARD — API KEYS CONFIG
# Salin ke .env dan isi hanya yang dibutuhkan
# ============================================

# ── AI PROVIDERS (isi minimal satu) ──────────────────────────────────────────

# Claude (Anthropic) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ChatGPT (OpenAI) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Gemini (Google) — https://aistudio.google.com/apikey  ← GRATIS
GEMINI_API_KEY=your_gemini_api_key_here

# Perplexity Sonar — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Grok (xAI) — https://console.x.ai  ← $25 free credits/bulan
# OpenAI-compatible API, model: grok-3, grok-3-mini
XAI_API_KEY=your_xai_api_key_here

# ── MESSAGING CHANNELS (opsional) ────────────────────────────────────────────

# Telegram Bot
# Setup: @BotFather → /newbot → tambahkan bot ke channel sebagai admin
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here   # @channel atau -100xxxxxxxxxx

# Discord Webhook
# Setup: Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── DATA SOURCES ──────────────────────────────────────────────────────────────

# FRED (St. Louis Fed) — https://fred.stlouisfed.org/docs/api/api_key.html  ← GRATIS
FRED_API_KEY=your_fred_api_key_here

# Twelve Data — https://twelvedata.com/  ← GRATIS (800 req/hari)
TWELVE_DATA_API_KEY=your_twelve_data_key_here

# Alpha Vantage — https://www.alphavantage.co/support/#api-key  ← GRATIS (25 req/hari)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# OilPriceAPI — https://www.oilpriceapi.com/  ← GRATIS (200 req/bulan)
OIL_PRICE_API_KEY=your_oilprice_api_key_here

# CoinMarketCap API — https://coinmarketcap.com/api/documentation/v1/
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here
